    "ai": "^5.0.154",
    "eslint": "^10.2.1",
    "hono": "^4.12.8",
    "hono-mcp-server-sse-transport": "0.0.7",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
