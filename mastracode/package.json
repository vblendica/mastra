{
  "name": "mastracode",
  "version": "0.16.1",
  "description": "",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "homepage": "https://mastra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastra-ai/mastra.git",
    "directory": "mastracode"
  },
  "bugs": {
    "url": "https://github.com/mastra-ai/mastra/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mastracode": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./tui": {
      "import": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.js"
      },
      "require": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "cli": "tsx src/main.ts",
    "check": "tsc --noEmit",
    "build:lib": "tsup --silent --config tsup.config.ts",
    "prepack": "pnpx tsx ../scripts/generate-package-docs.ts",
    "build:watch": "pnpm build --watch",
    "test": "vitest",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ast-grep/napi": "^0.42.0",
    "@mariozechner/pi-tui": "^0.60.0",
    "@mastra/agent-browser": "workspace:*",
    "@mastra/core": "workspace:*",
    "@mastra/duckdb": "workspace:*",
    "@mastra/fastembed": "workspace:*",
    "@mastra/libsql": "workspace:*",
    "@mastra/mcp": "workspace:*",
    "@mastra/memory": "workspace:*",
    "@mastra/observability": "workspace:*",
    "@mastra/pg": "workspace:*",
    "@mastra/stagehand": "workspace:*",
    "@mastra/tavily": "workspace:*",
    "ai": "^6.0.168",
    "chalk": "^5.5.0",
    "cli-highlight": "^2.1.11",
    "execa": "^9.6.1",
    "fastest-levenshtein": "^1.0.16",
    "js-tiktoken": "^1.0.21",
    "partial-json": "^0.1.7",
    "strip-ansi": "^7.2.0",
    "tree-kill": "^1.2.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@internal/lint": "workspace:*",
    "@internal/types-builder": "workspace:*",
    "@types/node": "22.19.15",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "^10.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.57.0",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
